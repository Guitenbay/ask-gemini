# Proxy URL for accessing Gemini (required if behind a firewall)
# PROXY_URL=http://127.0.0.1:7890

# Gemini cookies — copy from Chrome DevTools > Application > Cookies
# Or leave empty to auto-detect from your browser
# GEMINI_PSID=
# GEMINI_PSIDTS=

# Optional: default model
# MODEL=gemini-3-pro

# Rate limiting — human-like delays to avoid triggering Google risk control
# Enabled by default. Set RATE_LIMIT=0 to disable.
# RATE_LIMIT=1

# Typing speed in seconds per character (default: 0.05 ≈ 20 chars/sec)
# TYPING_SPEED=0.05

# Min delay before sending, even for short messages (seconds)
# MIN_DELAY=1.0

# Max delay cap for long messages (seconds)
# MAX_DELAY=5.0

# Cooldown after receiving a response before next request (seconds)
# COOLDOWN=2.0
